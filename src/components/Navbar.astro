---
import config from '@utils/config';
import { t, localeFlags, localeNames } from '@utils/i18n';

interface Props {
  locale: string;
  localeData: any;
}

const { locale, localeData } = Astro.props;
const availableLocales = config.locale.available;

const navLinks = [
  { href: '/shop', key: 'nav.shop', icon: 'shop' },
  { href: '/rules', key: 'nav.rules', icon: 'rules' },
  { href: '/about', key: 'nav.about', icon: 'about' },
];

const currentPath = Astro.url.pathname;

const pixelIcon = (name: string) => {
  const icons: Record<string, string> = {
    shop: `<svg viewBox="0 0 12 12" fill="currentColor" class="w-3.5 h-3.5 opacity-60 shrink-0"><rect x="2" y="1" width="2" height="2"/><rect x="8" y="1" width="2" height="2"/><rect x="1" y="3" width="10" height="8"/><rect x="3" y="5" width="6" height="4" fill="rgba(0,0,0,0.3)"/></svg>`,
    rules: `<svg viewBox="0 0 10 12" fill="currentColor" class="w-3.5 h-3.5 opacity-60 shrink-0"><rect x="2" y="1" width="6" height="10"/><rect x="3" y="3" width="4" height="1" fill="rgba(0,0,0,0.3)"/><rect x="3" y="5" width="4" height="1" fill="rgba(0,0,0,0.3)"/><rect x="3" y="7" width="3" height="1" fill="rgba(0,0,0,0.3)"/></svg>`,
    about: `<svg viewBox="0 0 10 12" fill="currentColor" class="w-3.5 h-3.5 opacity-60 shrink-0"><rect x="3" y="1" width="4" height="3"/><rect x="2" y="5" width="6" height="6"/><rect x="4" y="6" width="2" height="1" fill="rgba(0,0,0,0.3)"/><rect x="4" y="8" width="2" height="1" fill="rgba(0,0,0,0.3)"/></svg>`,
    language: `<svg viewBox="0 0 12 12" fill="currentColor" class="w-3.5 h-3.5 opacity-60 shrink-0"><rect x="4" y="1" width="4" height="1"/><rect x="2" y="2" width="2" height="1"/><rect x="8" y="2" width="2" height="1"/><rect x="1" y="3" width="1" height="6"/><rect x="10" y="3" width="1" height="6"/><rect x="4" y="10" width="4" height="1"/><rect x="2" y="9" width="2" height="1"/><rect x="8" y="9" width="2" height="1"/><rect x="5" y="3" width="2" height="6"/></svg>`,
  };
  return icons[name] || '';
};
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white/[0.02] backdrop-blur-2xl bg-grid transition-transform duration-300 ease-out">
  <div class="mx-auto max-w-6xl px-5 h-14 flex items-center justify-between">
    
    <!-- Left group -->
    <div class="flex items-center gap-1">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 mr-4 group">
        <img
          src="/images/logo.png"
          alt={config.server.name}
          class="h-8 w-auto object-contain"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
        />
        <div class="w-8 h-8 rounded-sm bg-[#F7EE13] hidden items-center justify-center text-sm">
          ⚔
        </div>
        <span class="font-pixel text-sm text-white/90 group-hover:text-white transition-colors tracking-wide hidden sm:inline">
          {config.server.name}
        </span>
      </a>
      
      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-0.5">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`flex items-center gap-1.5 px-3 py-1.5 rounded-sm font-pixel text-[11px] transition-all duration-200 ${
              currentPath === link.href
                ? 'text-white bg-white/[0.08]'
                : 'text-white/40 hover:text-white/70 hover:bg-white/[0.04]'
            }`}
          >
            <Fragment set:html={pixelIcon(link.icon)} />
            {t(localeData, link.key)}
          </a>
        ))}
      </div>
      
      <!-- Discord -->
      <a
        href={config.server.discordUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:flex items-center gap-1.5 px-3 py-1.5 rounded-sm text-white/40 hover:text-white/70 hover:bg-white/[0.04] transition-all font-pixel text-[11px]"
      >
        <svg class="w-3.5 h-3.5 text-[#5865F2] shrink-0" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"/>
        </svg>
        <span class="hidden lg:inline">{t(localeData, 'nav.discord')}</span>
      </a>
    </div>
    
    <!-- Right group -->
    <div class="flex items-center gap-2 h-full">
      <!-- Language -->
      <div class="relative group/lang h-full flex items-center" id="lang-menu">
        <button
          type="button"
          id="lang-trigger"
          aria-haspopup="true"
          aria-expanded="false"
          class="flex items-center gap-2 h-full px-2.5 hover:bg-white/[0.04] transition-all"
        >
          <Fragment set:html={pixelIcon('language')} />
          <span class="font-pixel text-xs text-white/50 hidden sm:inline">{localeNames[locale] || locale}</span>
          <svg class="w-3 h-3 text-white/30 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        
        <div id="lang-dropdown" class="absolute right-0 top-full w-40 bg-white/[0.03] backdrop-blur-2xl border border-white/[0.06] border-t-0 opacity-0 invisible group-hover/lang:opacity-100 group-hover/lang:visible transition-all duration-200 overflow-hidden z-50">
          {availableLocales.map(lang => {
            const switchUrl = new URL(Astro.url);
            switchUrl.searchParams.set('lang', lang);
            return (
              <a
                href={switchUrl.pathname + switchUrl.search}
                data-lang={lang}
                class={`lang-option flex items-center gap-3 px-4 py-2.5 font-pixel text-xs transition-all ${
                  locale === lang
                    ? 'bg-white/[0.06] text-[#F7EE13]'
                    : 'text-white/50 hover:bg-white/[0.04] hover:text-white/80'
                }`}
              >
                <img
                  src={localeFlags[lang] || localeFlags['en']}
                  alt={lang}
                  class="w-4 h-4 rounded-full object-cover"
                  onerror="this.style.display='none'"
                />
                {localeNames[lang] || lang}
              </a>
            );
          })}
        </div>
      </div>
      
      <!-- Mobile toggle -->
      <button
        type="button"
        id="mobile-toggle"
        class="md:hidden p-2 rounded-sm hover:bg-white/[0.04] transition-all"
      >
        <svg class="w-4 h-4 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
  
  <!-- Grid line -->
  <div class="h-px bg-white"></div>
  
  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white/[0.03] backdrop-blur-2xl">
    <div class="mx-auto max-w-6xl px-5 pb-3">
      <div class="flex flex-col gap-0.5 pt-2">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`flex items-center gap-2 px-3 py-2.5 rounded-sm font-pixel text-xs transition-all ${
              currentPath === link.href
                ? 'text-white bg-white/[0.06]'
                : 'text-white/40 hover:text-white/70 hover:bg-white/[0.03]'
            }`}
          >
            <Fragment set:html={pixelIcon(link.icon)} />
            {t(localeData, link.key)}
          </a>
        ))}
        <a
          href={config.server.discordUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 px-3 py-2.5 rounded-sm font-pixel text-xs text-white/40 hover:text-white/70 hover:bg-white/[0.03] transition-all"
        >
          <svg class="w-4 h-4 text-[#5865F2] shrink-0" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"/>
          </svg>
          Discord
        </a>
      </div>

      <div class="mt-3 border-t border-white/[0.06] pt-3">
        <div class="px-3 pb-2 font-pixel text-xs text-white/30 uppercase tracking-[0.15em]">Language</div>
        <div class="flex flex-col gap-0.5">
          {availableLocales.map(lang => {
            const switchUrl = new URL(Astro.url);
            switchUrl.searchParams.set('lang', lang);
            return (
              <a
                href={switchUrl.pathname + switchUrl.search}
                data-lang={lang}
                class={`lang-option flex items-center gap-3 px-3 py-2.5 rounded-sm font-pixel text-xs transition-all ${
                  locale === lang
                    ? 'text-[#F7EE13] bg-white/[0.06]'
                    : 'text-white/40 hover:text-white/70 hover:bg-white/[0.03]'
                }`}
              >
                <img
                  src={localeFlags[lang] || localeFlags['en']}
                  alt={lang}
                  class="w-4 h-4 rounded-full object-cover"
                  onerror="this.style.display='none'"
                />
                {localeNames[lang] || lang}
              </a>
            );
          })}
        </div>
      </div>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));

  const langMenu = document.getElementById('lang-menu');
  const langTrigger = document.getElementById('lang-trigger');
  const langDropdown = document.getElementById('lang-dropdown');
  const langOptions = document.querySelectorAll('.lang-option');

  const setLangOpen = (open) => {
    if (!langTrigger || !langDropdown) return;
    langTrigger.setAttribute('aria-expanded', open ? 'true' : 'false');
    langDropdown.classList.toggle('opacity-100', open);
    langDropdown.classList.toggle('visible', open);
    langDropdown.classList.toggle('opacity-0', !open);
    langDropdown.classList.toggle('invisible', !open);
  };

  langTrigger?.addEventListener('click', (event) => {
    event.preventDefault();
    event.stopPropagation();
    const isOpen = langTrigger.getAttribute('aria-expanded') === 'true';
    setLangOpen(!isOpen);
  });

  document.addEventListener('click', (event) => {
    if (!langMenu?.contains(event.target)) {
      setLangOpen(false);
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      setLangOpen(false);
    }
  });

  langOptions.forEach((option) => {
    option.addEventListener('click', () => {
      const nextLang = option.getAttribute('data-lang');
      if (nextLang) {
        document.cookie = `lang=${nextLang};path=/;max-age=31536000;SameSite=Lax`;
      }
      setLangOpen(false);
    });
  });

  // Hide navbar on scroll down, show on scroll up
  const nav = document.querySelector('nav');
  let lastScrollY = window.scrollY;
  let ticking = false;

  function onScroll() {
    const currentScrollY = window.scrollY;
    if (currentScrollY <= 10) {
      nav?.classList.remove('-translate-y-full');
    } else if (currentScrollY > lastScrollY) {
      nav?.classList.add('-translate-y-full');
    } else {
      nav?.classList.remove('-translate-y-full');
    }
    lastScrollY = currentScrollY;
    ticking = false;
  }

  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(onScroll);
      ticking = true;
    }
  });
</script>
