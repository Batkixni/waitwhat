---
import config from '@utils/config';
import { t, localeFlags, localeNames } from '@utils/i18n';
import { Book, ChevronDown, Info, Languages, Menu, Store } from '@lucide/astro';

interface Props {
  locale: string;
  localeData: any;
}

const { locale, localeData } = Astro.props;
const availableLocales = config.locale.available;

const navLinks = [
  { href: '/shop', key: 'nav.shop', Icon: Store },
  { href: '/rules', key: 'nav.rules', Icon: Book },
  { href: '/about', key: 'nav.about', Icon: Info },
];

const currentPath = Astro.url.pathname;
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white/[0.02] backdrop-blur-2xl transition-transform duration-300 ease-out">

  <div class="relative mx-auto max-w-6xl px-5 h-14 flex items-center justify-between">
    
    <!-- Left group -->
    <div class="flex h-full items-center gap-1 border-l border-white/[0.10] pl-6">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 mr-4 group" aria-label={config.server.name}>
        <img
          src="/images/logo.png"
          alt={config.server.name}
          class="h-7 w-auto object-contain"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
        />
        <div class="w-8 h-8 rounded-sm bg-[#F7EE13] hidden items-center justify-center text-sm">
          ⚔
        </div>
        <img
          src="/images/branding/banner-fusion-pixel-8px.png"
          alt={config.server.name}
          class="h-4 w-auto object-contain opacity-90 group-hover:opacity-100 transition-opacity hidden sm:block"
          onerror="this.style.display='none'"
        />
      </a>
      
      <!-- Divider -->
      <div class="w-px self-stretch bg-white/20 hidden md:block"></div>
      
      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-0.5">
        {navLinks.map(({ href, key, Icon }) => (
          <a
            href={href}
            class={`flex items-center gap-1.5 px-3 py-1.5 rounded-sm font-pixel text-xs text-white transition-all duration-200 ${
              currentPath === href
                ? 'bg-white/[0.08]'
                : 'hover:bg-white/[0.04]'
            }`}
          >
            <Icon class="w-3.5 h-3.5 text-white shrink-0" stroke-width={2} aria-hidden="true" />
            {t(localeData, key)}
          </a>
        ))}
      </div>
      
      <!-- Discord -->
      <a
        href={config.server.discordUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:flex items-center gap-1.5 px-3 py-1.5 rounded-sm text-white hover:bg-white/[0.04] transition-all font-pixel text-xs"
      >
        <svg class="w-3.5 h-3.5 text-white shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
        </svg>
        <span class="hidden lg:inline">{t(localeData, 'nav.discord')}</span>
      </a>
    </div>
    
    <!-- Right group -->
    <div class="flex items-center gap-0 h-full flex-1 justify-end">
      <!-- Language -->
      <div class="relative group/lang h-full min-w-[180px] border-l border-r border-white/[0.08] flex items-center" id="lang-menu">
        <button
          type="button"
          id="lang-trigger"
          aria-haspopup="true"
          aria-expanded="false"
          class="flex items-center justify-center gap-2 h-full w-full px-4 text-white hover:bg-white/[0.04] transition-all"
        >
          <Languages class="w-3.5 h-3.5 text-white shrink-0" stroke-width={2} aria-hidden="true" />
          <span class="font-pixel text-xs text-white hidden sm:inline">{localeNames[locale] || locale}</span>
          <ChevronDown class="w-3 h-3 text-white shrink-0" stroke-width={2} aria-hidden="true" />
        </button>
        
        <div id="lang-dropdown" class="absolute left-0 right-0 top-[calc(100%+1px)] w-full bg-white/[0.06] backdrop-blur-2xl border-x border-b border-white/[0.08] opacity-0 invisible group-hover/lang:opacity-100 group-hover/lang:visible transition-all duration-200 overflow-hidden shadow-[0_8px_30px_rgba(0,0,0,0.3)] z-50">
          {availableLocales.map(lang => {
            const switchUrl = new URL(Astro.url);
            switchUrl.searchParams.set('lang', lang);
            return (
              <a
                href={switchUrl.pathname + switchUrl.search}
                data-lang={lang}
                class={`lang-option flex items-center gap-3 px-4 py-2.5 font-pixel text-xs transition-all ${
                  locale === lang
                    ? 'bg-white/[0.06] text-[#F7EE13]'
                    : 'text-white/50 hover:bg-white/[0.04] hover:text-white/80'
                }`}
              >
                <img
                  src={localeFlags[lang] || localeFlags['en']}
                  alt={lang}
                  class="w-4 h-4 rounded-full object-cover"
                  onerror="this.style.display='none'"
                />
                {localeNames[lang] || lang}
              </a>
            );
          })}
        </div>
      </div>
      
      <!-- Mobile toggle -->
      <button
        type="button"
        id="mobile-toggle"
        class="md:hidden p-2 rounded-sm text-white hover:bg-white/[0.04] transition-all"
      >
        <Menu class="w-4 h-4 text-white" stroke-width={2} aria-hidden="true" />
      </button>
    </div>
  </div>
  
  <!-- Grid line -->
  <div class="module-line"></div>
  
  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white/[0.03] backdrop-blur-2xl">
    <div class="mx-auto max-w-6xl px-5 pb-3">
      <div class="flex flex-col gap-0.5 pt-2">
        {navLinks.map(({ href, key, Icon }) => (
          <a
            href={href}
            class={`flex items-center gap-2 px-3 py-2.5 rounded-sm font-pixel text-xs text-white transition-all ${
              currentPath === href
                ? 'bg-white/[0.06]'
                : 'hover:bg-white/[0.03]'
            }`}
          >
            <Icon class="w-4 h-4 text-white shrink-0" stroke-width={2} aria-hidden="true" />
            {t(localeData, key)}
          </a>
        ))}
        <a
          href={config.server.discordUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 px-3 py-2.5 rounded-sm font-pixel text-xs text-white hover:bg-white/[0.03] transition-all"
        >
          <svg class="w-4 h-4 text-white shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
          </svg>
          Discord
        </a>
      </div>

      <div class="mt-3 border-t border-white/[0.06] pt-3">
        <div class="px-3 pb-2 font-pixel text-xs text-white/30 uppercase tracking-[0.15em]">Language</div>
        <div class="flex flex-col gap-0.5">
          {availableLocales.map(lang => {
            const switchUrl = new URL(Astro.url);
            switchUrl.searchParams.set('lang', lang);
            return (
              <a
                href={switchUrl.pathname + switchUrl.search}
                data-lang={lang}
                class={`lang-option flex items-center gap-3 px-3 py-2.5 rounded-sm font-pixel text-xs transition-all ${
                  locale === lang
                    ? 'text-[#F7EE13] bg-white/[0.06]'
                    : 'text-white/40 hover:text-white/70 hover:bg-white/[0.03]'
                }`}
              >
                <img
                  src={localeFlags[lang] || localeFlags['en']}
                  alt={lang}
                  class="w-4 h-4 rounded-full object-cover"
                  onerror="this.style.display='none'"
                />
                {localeNames[lang] || lang}
              </a>
            );
          })}
        </div>
      </div>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));

  const langMenu = document.getElementById('lang-menu');
  const langTrigger = document.getElementById('lang-trigger');
  const langDropdown = document.getElementById('lang-dropdown');
  const langOptions = document.querySelectorAll('.lang-option');

  const setLangOpen = (open) => {
    if (!langTrigger || !langDropdown) return;
    langTrigger.setAttribute('aria-expanded', open ? 'true' : 'false');
    langDropdown.classList.toggle('opacity-100', open);
    langDropdown.classList.toggle('visible', open);
    langDropdown.classList.toggle('opacity-0', !open);
    langDropdown.classList.toggle('invisible', !open);
  };

  langTrigger?.addEventListener('click', (event) => {
    event.preventDefault();
    event.stopPropagation();
    const isOpen = langTrigger.getAttribute('aria-expanded') === 'true';
    setLangOpen(!isOpen);
  });

  document.addEventListener('click', (event) => {
    if (!langMenu?.contains(event.target)) {
      setLangOpen(false);
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      setLangOpen(false);
    }
  });

  langOptions.forEach((option) => {
    option.addEventListener('click', () => {
      const nextLang = option.getAttribute('data-lang');
      if (nextLang) {
        document.cookie = `lang=${nextLang};path=/;max-age=31536000;SameSite=Lax`;
      }
      setLangOpen(false);
    });
  });

  // Hide navbar on scroll down, show on scroll up
  const nav = document.querySelector('nav');
  let lastScrollY = window.scrollY;
  let ticking = false;

  function onScroll() {
    const currentScrollY = window.scrollY;
    if (currentScrollY <= 10) {
      nav?.classList.remove('-translate-y-full');
    } else if (currentScrollY > lastScrollY) {
      nav?.classList.add('-translate-y-full');
    } else {
      nav?.classList.remove('-translate-y-full');
    }
    lastScrollY = currentScrollY;
    ticking = false;
  }

  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(onScroll);
      ticking = true;
    }
  });
</script>
