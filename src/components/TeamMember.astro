---
interface Props {
  username: string;
  rank?: string;
  size?: 'sm' | 'md' | 'lg';
}

const { username, size = 'md' } = Astro.props;

const sizes = {
  sm: 'w-12 h-12',
  md: 'w-16 h-16',
  lg: 'w-20 h-20'
};

const textSizes = {
  sm: 'text-[9px]',
  md: 'text-[10px]',
  lg: 'text-xs'
};

// Deterministic UUID from username string
function strToUUID(str: string): string {
  let h = 0;
  for (let i = 0; i < str.length; i++) h = str.charCodeAt(i) + ((h << 5) - h);
  const hex = Math.abs(h).toString(16).padStart(32, '0');
  return `${hex.slice(0,8)}-${hex.slice(8,12)}-4${hex.slice(13,16)}-a${hex.slice(17,20)}-${hex.slice(20,32)}`;
}

const uuid = strToUUID(username);
const avatarUrl = `https://api.mineatar.io/face/${uuid}`;
const fallbackUrl = 'https://api.mineatar.io/face/069a79f4-44e9-4726-a5be-fca90e38aaf5';
---

<div class="flex flex-col items-center gap-2 group">
  <div class={`${sizes[size]} overflow-hidden rounded-sm border border-white/[0.08] bg-white/[0.03] shadow-[0_0_0_1px_rgba(255,255,255,0.03)_inset] transition-all duration-300 group-hover:-translate-y-1 group-hover:border-[#F7EE13]/24`}>
    <img
      src={avatarUrl}
      alt={username}
      class="w-full h-full object-cover image-render-pixel"
      onerror={`this.src='${fallbackUrl}'`}
      loading="lazy"
    />
  </div>
  <div class={`font-pixel ${textSizes[size]} text-center text-white/72 group-hover:text-white/92 transition-colors tracking-[0.06em]`}>
    {username}
  </div>
</div>
