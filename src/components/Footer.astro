---
import config from '@utils/config';
import { t } from '@utils/i18n';

interface Props {
  locale: string;
  localeData: any;
}

const { localeData } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="relative z-10 border-t border-white/[0.06] mt-24">
  <div class="max-w-6xl mx-auto px-5 py-16">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-10">
      
      <!-- Server -->
      <div class="col-span-2 md:col-span-1">
        <div class="flex items-center gap-2.5 mb-4">
          <div class="w-7 h-7 rounded-md bg-[#F97316]/10 flex items-center justify-center text-xs">
            ⚔
          </div>
          <span class="font-pixel text-sm text-white/80">{config.server.name}</span>
        </div>
        <p class="font-pixel text-[10px] text-white/30 leading-relaxed max-w-[180px]">
          {t(localeData, 'footer.server.description')}
        </p>
      </div>
      
      <!-- More Info -->
      <div>
        <h4 class="font-pixel text-[11px] text-white/50 mb-4 tracking-wide">{t(localeData, 'footer.moreInfo.title')}</h4>
        <ul class="space-y-2.5">
          {['home','about','rules','shop'].map(k => (
            <li>
              <a href={`/${k === 'home' ? '' : k}`} class="font-pixel text-[10px] text-white/25 hover:text-[#F97316] transition-colors">
                {t(localeData, `footer.moreInfo.links.${k}`)}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <!-- Resources -->
      <div>
        <h4 class="font-pixel text-[11px] text-white/50 mb-4 tracking-wide">{t(localeData, 'footer.resources.title')}</h4>
        <ul class="space-y-2.5">
          {['vote','status','bugs'].map(k => (
            <li>
              <a href={k === 'status' ? '/api/status' : '#'} class="font-pixel text-[10px] text-white/25 hover:text-[#F97316] transition-colors">
                {t(localeData, `footer.resources.links.${k}`)}
              </a>
            </li>
          ))}
        </ul>
      </div>
      
      <!-- Social -->
      <div>
        <h4 class="font-pixel text-[11px] text-white/50 mb-4 tracking-wide">{t(localeData, 'footer.social.title')}</h4>
        <ul class="space-y-2.5">
          <li>
            <a href={config.server.discordUrl} target="_blank" rel="noopener" class="font-pixel text-[10px] text-white/25 hover:text-[#5865F2] transition-colors flex items-center gap-1.5">
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.79 19.79 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.865-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 00.533 9.046a.07.07 0 00-.032.028C-.319 13.58.1 18.058.43 22.535a.078.078 0 00.031.056c2.053 1.508 4.041 2.423 5.993 3.03a.077.077 0 00.084-.028c.462-.63.873-1.295 1.226-1.994a.076.076 0 00-.042-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128c.126-.094.252-.192.372-.291a.074.074 0 01.078-.011c3.927 1.793 8.18 1.793 12.061 0a.074.074 0 01.079.01c.12.099.246.198.372.292a.077.077 0 01-.007.128 12.299 12.299 0 01-1.873.891.076.076 0 00-.04.107c.36.698.772 1.363 1.225 1.993a.076.076 0 00.084.028c1.961-.607 3.95-1.522 6.002-3.029a.077.077 0 00.032-.055c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.029zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.332-.955 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.095 2.157 2.42 0 1.332-.946 2.418-2.157 2.418z"/></svg>
              Discord
            </a>
          </li>
          <li><a href="#" class="font-pixel text-[10px] text-white/25 hover:text-white/60 transition-colors">{t(localeData, 'footer.social.links.twitter')}</a></li>
          <li><a href="#" class="font-pixel text-[10px] text-white/25 hover:text-white/60 transition-colors">{t(localeData, 'footer.social.links.youtube')}</a></li>
          <li><a href="#" class="font-pixel text-[10px] text-white/25 hover:text-white/60 transition-colors">{t(localeData, 'footer.social.links.tiktok')}</a></li>
        </ul>
      </div>
      
      <!-- Copyright -->
      <div class="col-span-2 md:col-span-1">
        <p class="font-pixel text-[10px] text-white/20 leading-relaxed">
          {t(localeData, 'footer.copyright', { year: year.toString() })}
        </p>
        <p class="font-pixel text-[9px] text-white/15 mt-3">
          {t(localeData, 'footer.disclaimer')}
        </p>
      </div>
    </div>
  </div>
</footer>
