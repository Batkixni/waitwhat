---
import config from '@utils/config';
import { t } from '@utils/i18n';

interface Props {
  locale: string;
  localeData: any;
}

const { localeData } = Astro.props;
const year = new Date().getFullYear();

const primaryLinks = [
  { href: '/', key: 'footer.moreInfo.links.home' },
  { href: '/about', key: 'footer.moreInfo.links.about' },
  { href: '/rules', key: 'footer.moreInfo.links.rules' },
  { href: '/shop', key: 'footer.moreInfo.links.shop' },
];

const socialLinks = [
  { href: config.server.discordUrl, label: 'Discord' },
  { href: '#', label: t(localeData, 'footer.social.links.twitter') },
  { href: '#', label: t(localeData, 'footer.social.links.youtube') },
  { href: '#', label: t(localeData, 'footer.social.links.tiktok') },
];
---

<footer class="relative z-10 mt-24 border-t border-white/[0.06]">
  <div class="max-w-6xl mx-auto px-5 py-14">
    <div class="flex flex-col gap-12 lg:flex-row lg:items-start lg:justify-between">
      <div class="max-w-xl">
        <div class="flex items-center gap-4 mb-5">
          <div class="w-14 h-14 rounded-sm bg-[#F7EE13] flex items-center justify-center text-2xl text-black border border-[#F7EE13]/40">
            ⚔
          </div>
          <div>
            <div class="font-pixel text-xl sm:text-2xl text-white/95 leading-none">{config.server.name}</div>
            <div class="font-pixel text-sm text-[#F7EE13]/70 mt-2 tracking-wide">Minecraft Network</div>
          </div>
        </div>

        <p class="font-pixel text-sm sm:text-base text-white/45 leading-8 max-w-lg">
          {t(localeData, 'footer.server.description')}
        </p>
      </div>

      <div class="flex flex-col gap-8 lg:items-end">
        <nav class="flex flex-wrap gap-x-8 gap-y-4 lg:justify-end">
          {primaryLinks.map(link => (
            <a href={link.href} class="font-pixel text-sm sm:text-base text-white/55 hover:text-[#F7EE13] transition-colors">
              {t(localeData, link.key)}
            </a>
          ))}
        </nav>

        <div class="flex flex-wrap gap-x-8 gap-y-4 lg:justify-end">
          {socialLinks.map(link => (
            <a href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined} class="font-pixel text-sm sm:text-base text-white/35 hover:text-white/75 transition-colors">
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="mt-12 pt-6 border-t border-white/[0.04] flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
      <p class="font-pixel text-xs sm:text-sm text-white/28 leading-relaxed">
        {t(localeData, 'footer.copyright', { year: year.toString() })}
      </p>
      <p class="font-pixel text-xs sm:text-sm text-white/20 leading-relaxed lg:text-right">
        {t(localeData, 'footer.disclaimer')}
      </p>
    </div>
  </div>
</footer>
