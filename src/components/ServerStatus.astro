---
import config from '@utils/config';
import ServerStatusBeam from '@components/ui/server-status-beam';

interface Props {
  localeData: any;
}

const { localeData } = Astro.props;
const serverIp = config.server.ip;
const isDev = import.meta.env.DEV;
---

<ServerStatusBeam
  client:only="react"
  serverIp={serverIp}
  offlineLabel={localeData.home?.serverStatus?.offline || 'Offline'}
  onlineLabel={localeData.home?.serverStatus?.online || 'Online'}
  playersLabel={localeData.home?.serverStatus?.players || 'players'}
  initialOffline={isDev}
/>
