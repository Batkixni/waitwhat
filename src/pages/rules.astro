---
import MainLayout from '@layouts/MainLayout.astro';
import { loadLocale, detectLocale, t, tArray } from '@utils/i18n';
import config from '@utils/config';

const { cookies, request } = Astro;
const locale = detectLocale(cookies, request.headers, Astro.url);
const localeData = await loadLocale(locale);

const rules = tArray(localeData, 'rules.sections');
const lastUpdated = config.rules.lastUpdated;
---

<MainLayout
  title={t(localeData, 'rules.meta.title')}
  description={t(localeData, 'rules.meta.description')}
>
  <section class="relative z-10 min-h-screen px-5 pt-28 pb-24">
    <div class="max-w-4xl mx-auto">

      <!-- Header -->
      <div class="text-center mb-16">
        <p class="reveal font-pixel text-xs text-[#F7EE13]/55 tracking-[0.18em] uppercase mb-4" style="--delay: 0ms">RULES</p>
        <h1 class="reveal font-pixel text-3xl sm:text-4xl lg:text-5xl text-white/95 mb-5" style="--delay: 80ms">{t(localeData, 'rules.title')}</h1>
        <div class="reveal inline-flex items-center gap-2.5 px-4 py-2 rounded-sm bg-white/[0.025] border border-white/[0.07]" style="--delay: 160ms">
          <svg class="w-3.5 h-3.5 text-white/25" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <span class="font-pixel text-xs text-white/40">{t(localeData, 'rules.lastUpdated')}: {lastUpdated}</span>
        </div>
      </div>

      <!-- Rules - single column flow -->
      <div class="flex flex-col">
        {rules.map((section: any, index: number) => (
          <div class="module-divider-top relative">
            <!-- Section header -->
            <div class="reveal flex items-center gap-4 py-6" style={`--delay: ${index * 100}ms`}>
              <div class="w-9 h-9 rounded-sm bg-[#F7EE13]/7 border border-[#F7EE13]/15 flex items-center justify-center shrink-0">
                <span class="font-pixel text-xs text-[#F7EE13]/75">{index + 1}</span>
              </div>
              <h2 class="font-pixel text-xl sm:text-2xl text-white/85">{section.title}</h2>
            </div>

            <!-- Rules list -->
            <ul class="pb-10">
              {section.rules.map((rule: string, i: number) => (
                <li class="reveal flex items-start gap-4 py-4 border-t border-white/[0.04]" style={`--delay: ${index * 100 + (i + 1) * 60}ms`}>
                  <span class="flex-shrink-0 w-6 h-6 rounded-sm bg-white/[0.03] border border-white/[0.06] flex items-center justify-center mt-0.5">
                    <span class="font-pixel text-[10px] text-white/30">{i + 1}</span>
                  </span>
                  <span class="font-pixel text-sm sm:text-[15px] text-white/55 leading-8">{rule}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      {rules.length === 0 && (
        <div class="text-center py-20">
          <div class="reveal w-14 h-14 rounded-sm bg-white/[0.02] border border-white/[0.06] flex items-center justify-center mx-auto mb-4" style="--delay: 0ms">
            <svg class="w-6 h-6 text-white/8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
          </div>
          <p class="font-pixel text-xs text-white/25">No rules configured.</p>
        </div>
      )}
    </div>
  </section>
</MainLayout>
