---
import MainLayout from '@layouts/MainLayout.astro';
import { loadLocale, detectLocale, t, currencyFlags, currencySymbols } from '@utils/i18n';
import config from '@utils/config';

const { cookies, request } = Astro;
const locale = detectLocale(cookies, request.headers, Astro.url);
const localeData = await loadLocale(locale);

const shop = config.shop;
const currencies = shop.currency.available;
const defaultCurrency = shop.currency.default;
---

<MainLayout
  title={t(localeData, 'shop.meta.title')}
  description={t(localeData, 'shop.meta.description')}
>
  <section class="relative z-10 px-5 pt-32 pb-20 min-h-screen">
    <div class="max-w-5xl mx-auto">
      
      <!-- Header -->
      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-5 mb-12">
        <div>
          <p class="reveal font-pixel text-[10px] text-[#F7EE13]/50 tracking-[0.15em] uppercase mb-2" style="--delay: 0ms">STORE</p>
          <h1 class="reveal font-pixel text-2xl sm:text-3xl text-white/90 mb-2" style="--delay: 60ms">{t(localeData, 'shop.title')}</h1>
          <p class="reveal font-pixel text-xs text-white/30" style="--delay: 120ms">{t(localeData, 'shop.description')}</p>
        </div>
        
        <div class="reveal flex items-center gap-2" style="--delay: 180ms">
          <!-- Currency -->
          <div class="relative group/curr">
            <button class="flex items-center gap-2 px-3 py-2 rounded-xl bg-white/[0.02] border border-white/[0.06] hover:border-white/[0.12] transition-all">
              <img id="curr-flag" src={currencyFlags[defaultCurrency] || currencyFlags['USD']} class="w-4 h-4 rounded-full object-cover" />
              <span id="curr-label" class="font-pixel text-[10px] text-white/60">{currencySymbols[defaultCurrency] || '$'}</span>
              <svg class="w-3 h-3 text-white/20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>
            
            <div class="absolute right-0 top-full mt-2 w-36 bg-[#0A0A0A] border border-white/[0.06] rounded-xl shadow-2xl opacity-0 invisible group-hover/curr:opacity-100 group-hover/curr:visible transition-all duration-200 overflow-hidden z-50">
              {currencies.map(curr => (
                <button type="button" class="currency-opt w-full flex items-center gap-3 px-4 py-2.5 font-pixel text-[10px] transition-all text-white/40 hover:bg-white/[0.04] hover:text-white/80"
                  data-currency={curr}
                >
                  <img src={currencyFlags[curr] || currencyFlags['USD']} class="w-4 h-4 rounded-full object-cover" />
                  {currencySymbols[curr] || curr}
                </button>
              ))}
            </div>
          </div>
          
          <!-- Cart -->
          <button id="cart-btn" class="flex items-center gap-2 px-3 py-2 rounded-xl bg-white/[0.02] border border-white/[0.06] hover:border-white/[0.12] transition-all relative"
          >
            <svg class="w-4 h-4 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
            <span class="font-pixel text-[10px] text-white/50">{t(localeData, 'shop.cart')}</span>
            <span id="cart-badge" class="absolute -top-1 -right-1 w-4 h-4 rounded-full bg-[#F7EE13] text-black font-pixel text-[8px] flex items-center justify-center hidden">0</span>
          </button>
        </div>
      </div>
      
      {!shop.enabled ? (
        <div class="reveal flex flex-col items-center justify-center py-24" style="--delay: 240ms">
          <div class="w-16 h-16 rounded-2xl bg-white/[0.02] border border-white/[0.06] flex items-center justify-center mb-5">
            <svg class="w-7 h-7 text-white/10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" /></svg>
          </div>
          <p class="font-pixel text-sm text-white/30">{t(localeData, 'shop.disabled')}</p>
        </div>
      ) : (
        <div class="reveal card p-10 text-center" style="--delay: 240ms">
          <div class="w-14 h-14 rounded-2xl bg-[#F7EE13]/5 border border-[#F7EE13]/10 flex items-center justify-center mx-auto mb-5 text-xl">
            🛒
          </div>
          <h3 class="font-pixel text-base text-white/70 mb-2">{shop.provider === 'tebex' ? 'Tebex Store' : 'MCSets Store'}</h3>
          <p class="font-pixel text-[10px] text-white/25 mb-6">{shop.provider === 'tebex' ? shop.tebexUrl : shop.mcsetsUrl}</p>
          <a href={shop.provider === 'tebex' ? shop.tebexUrl : shop.mcsetsUrl} target="_blank" rel="noopener" class="btn-primary"
          >
            Visit Store
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
        </div>
      )}
    </div>
  </section>
  
  <!-- Cart Drawer -->
  <div id="cart-drawer" class="fixed inset-y-0 right-0 w-full max-w-sm bg-[#0A0A0A] border-l border-white/[0.06] transform translate-x-full transition-transform duration-300 z-50"
  >
    <div class="flex flex-col h-full">
      <div class="flex items-center justify-between p-5 border-b border-white/[0.06]">
        <h3 class="font-pixel text-sm text-white/80">{t(localeData, 'shop.cart')}</h3>
        <button id="close-cart" class="p-2 rounded-lg hover:bg-white/[0.04] transition-all">
          <svg class="w-4 h-4 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>
      <div class="flex-1 flex flex-col items-center justify-center p-8">
        <div class="w-14 h-14 rounded-2xl bg-white/[0.02] border border-white/[0.06] flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-white/8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg>
        </div>
        <p class="font-pixel text-xs text-white/25">{t(localeData, 'shop.emptyCart')}</p>
      </div>
    </div>
  </div>
  <div id="cart-overlay" class="fixed inset-0 bg-black/40 backdrop-blur-sm hidden z-40 transition-opacity"></div>

  <script define:vars={{ currencyFlags, currencySymbols, defaultCurrency }}>
    document.querySelectorAll('.currency-opt').forEach(btn => {
      btn.addEventListener('click', () => {
        const curr = btn.dataset.currency;
        document.getElementById('curr-flag').src = currencyFlags[curr] || currencyFlags['USD'];
        document.getElementById('curr-label').textContent = currencySymbols[curr] || curr;
        document.cookie = `currency=${curr};path=/;max-age=31536000;SameSite=Lax`;
      });
    });

    const drawer = document.getElementById('cart-drawer');
    const overlay = document.getElementById('cart-overlay');
    const open = () => { drawer?.classList.remove('translate-x-full'); overlay?.classList.remove('hidden'); };
    const close = () => { drawer?.classList.add('translate-x-full'); overlay?.classList.add('hidden'); };
    document.getElementById('cart-btn')?.addEventListener('click', open);
    document.getElementById('close-cart')?.addEventListener('click', close);
    overlay?.addEventListener('click', close);
  </script>
</MainLayout>
