---
import MainLayout from '@layouts/MainLayout.astro';
import TeamMember from '@components/TeamMember.astro';
import { loadLocale, detectLocale, t } from '@utils/i18n';
import config from '@utils/config';

const { cookies, request } = Astro;
const locale = detectLocale(cookies, request.headers, Astro.url);
const localeData = await loadLocale(locale);

const milestones = config.milestones;

const teamRanks = config.team.ranks
  .sort((a, b) => a.priority - b.priority)
  .filter(rank => {
    const members = config.team.members[rank.id];
    return members && members.length > 0;
  });
---

<MainLayout
  title={t(localeData, 'about.meta.title')}
  description={t(localeData, 'about.meta.description')}
>
  <section class="relative z-10 px-5 pt-32 pb-20 min-h-screen">
    <div class="max-w-4xl mx-auto">
      
      <!-- About -->
      <div class="text-center mb-20">
        <p class="font-pixel text-[10px] text-[#F97316]/50 tracking-[0.15em] uppercase mb-3">ABOUT</p>
        <h1 class="font-pixel text-2xl sm:text-3xl text-white/90 mb-6">{t(localeData, 'about.title')}</h1>
        <p class="font-pixel text-xs text-white/35 max-w-2xl mx-auto leading-relaxed">
          {t(localeData, 'about.description')}
        </p>
      </div>
      
      <!-- Milestones -->
      <div class="mb-24">
        <div class="text-center mb-12">
          <p class="font-pixel text-[10px] text-[#F97316]/50 tracking-[0.15em] uppercase mb-3">TIMELINE</p>
          <h2 class="font-pixel text-xl text-white/80">{t(localeData, 'about.milestones.title')}</h2>
        </div>
        
        <div class="relative">
          <div class="absolute left-4 sm:left-1/2 top-0 bottom-0 w-px bg-white/[0.04] sm:-translate-x-px"></div>
          
          <div class="space-y-10">
            {milestones.map((m, index) => {
              const isEven = index % 2 === 0;
              return (
                <div class={`relative flex items-start gap-5 sm:gap-0 ${isEven ? 'sm:flex-row' : 'sm:flex-row-reverse'}`}>
                  <div class="absolute left-4 sm:left-1/2 w-2.5 h-2.5 rounded-full bg-[#F97316]/30 border-2 border-[#F97316]/50 -translate-x-[5px] mt-2 z-10"></div>
                  
                  <div class={`ml-10 sm:ml-0 sm:w-1/2 ${isEven ? 'sm:pr-10 sm:text-right' : 'sm:pl-10'}`}>
                    <span class="inline-block px-2.5 py-1 rounded-md bg-[#F97316]/[0.05] border border-[#F97316]/10 font-pixel text-[9px] text-[#F97316]/50 mb-2"
                    >{m.date}</span>
                    <h3 class="font-pixel text-sm text-white/70 mb-1">{m.title}</h3>
                    <p class="font-pixel text-[10px] text-white/30 leading-relaxed">{m.description}</p>
                  </div>
                  <div class="hidden sm:block sm:w-1/2"></div>
                </div>
              );
            })}
          </div>
        </div>
      </div>
      
      <!-- Team -->
      <div>
        <div class="text-center mb-12">
          <p class="font-pixel text-[10px] text-[#F97316]/50 tracking-[0.15em] uppercase mb-3">TEAM</p>
          <h2 class="font-pixel text-xl text-white/80">{t(localeData, 'about.team.title')}</h2>
        </div>
        
        <div class="space-y-14">
          {teamRanks.map(rank => {
            const members = config.team.members[rank.id] || [];
            return (
              <div>
                <div class="flex items-center gap-4 mb-6">
                  <div class="h-px flex-1 bg-white/[0.04]"></div>
                  <h3 class="font-pixel text-xs text-white/40 tracking-wide">{t(localeData, `about.team.ranks.${rank.id}`)}</h3>
                  <div class="h-px flex-1 bg-white/[0.04]"></div>
                </div>
                
                <div class="flex flex-wrap justify-center gap-5">
                  {members.map(username => (
                    <TeamMember username={username} rank={rank.id} size="md" />
                  ))}
                </div>
              </div>
            );
          })}
        </div>
        
        {teamRanks.length === 0 && (
          <div class="text-center py-12">
            <p class="font-pixel text-xs text-white/25">No team members configured.</p>
          </div>
        )}
      </div>
    </div>
  </section>
</MainLayout>