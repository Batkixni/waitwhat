---
import MainLayout from '@layouts/MainLayout.astro';
import TeamMember from '@components/TeamMember.astro';
import { loadLocale, detectLocale, t } from '@utils/i18n';
import config from '@utils/config';

const { cookies, request } = Astro;
const locale = detectLocale(cookies, request.headers, Astro.url);
const localeData = await loadLocale(locale);

const milestones = config.milestones;

const teamRanks = config.team.ranks
  .sort((a, b) => a.priority - b.priority)
  .filter(rank => {
    const members = config.team.members[rank.id];
    return members && members.length > 0;
  });

const rankBannerMap: Record<string, string> = {
  owner: 'owner.png',
  founder: 'fouder.png',
  developer: 'dev.png',
  admin: 'admin.png',
  builder: 'builder.png',
  mod: 'mod.png',
  jrmod: 'jr_mod.png',
  helper: 'helper.png',
  trial: 'trial.png',
  lens: 'lens.png',
};
---

<MainLayout
  title={t(localeData, 'about.meta.title')}
  description={t(localeData, 'about.meta.description')}
>
  <section class="relative z-10 px-5 pt-32 pb-20 min-h-screen">
    <div class="max-w-4xl mx-auto">
      
      <!-- About -->
      <div class="text-center mb-20">
        <p class="font-pixel text-[10px] text-[#F7EE13]/50 tracking-[0.15em] uppercase mb-3">ABOUT</p>
        <h1 class="font-pixel text-2xl sm:text-3xl text-white/90 mb-6">{t(localeData, 'about.title')}</h1>
        <p class="font-pixel text-xs text-white/35 max-w-2xl mx-auto leading-relaxed">
          {t(localeData, 'about.description')}
        </p>
      </div>
      
      <!-- Milestones -->
      <div class="mb-28">
        <div class="text-center mb-14">
          <p class="font-pixel text-[10px] text-[#F7EE13]/50 tracking-[0.15em] uppercase mb-3">TIMELINE</p>
          <h2 class="font-pixel text-2xl sm:text-3xl text-white/90">{t(localeData, 'about.milestones.title')}</h2>
        </div>
        
        <div class="relative max-w-5xl mx-auto">
          <div class="absolute left-5 sm:left-1/2 top-0 bottom-0 w-px bg-white/[0.06] sm:-translate-x-px"></div>
          
          <div class="space-y-14">
            {milestones.map((m, index) => {
              const isEven = index % 2 === 0;
              return (
                <div class={`relative flex items-start gap-6 sm:gap-0 ${isEven ? 'sm:flex-row' : 'sm:flex-row-reverse'}`}>
                  <div class="absolute left-5 sm:left-1/2 w-3 h-3 rounded-full bg-[#F7EE13]/30 border-2 border-[#F7EE13]/50 -translate-x-[6px] mt-3 z-10"></div>
                  
                  <div class={`ml-12 sm:ml-0 sm:w-1/2 ${isEven ? 'sm:pr-12 sm:text-right' : 'sm:pl-12'}`}>
                    <span class="inline-block px-3 py-1.5 rounded-md bg-[#F7EE13]/[0.05] border border-[#F7EE13]/10 font-pixel text-[10px] text-[#F7EE13]/60 mb-3"
                    >{m.date}</span>
                    <h3 class="font-pixel text-base sm:text-lg text-white/78 mb-2">{m.title}</h3>
                    <p class="font-pixel text-xs sm:text-sm text-white/38 leading-relaxed">{m.description}</p>
                  </div>
                  <div class="hidden sm:block sm:w-1/2"></div>
                </div>
              );
            })}
          </div>
        </div>
      </div>
      
      <!-- Team -->
      <div>
        <div class="text-center mb-12">
          <p class="font-pixel text-[10px] text-[#F7EE13]/50 tracking-[0.15em] uppercase mb-3">TEAM</p>
          <h2 class="font-pixel text-xl text-white/80">{t(localeData, 'about.team.title')}</h2>
        </div>
        
        <div class="space-y-12">
          {teamRanks.map((rank) => {
            const members = config.team.members[rank.id] || [];
            const bannerSrc = `/images/staff-nametags/${rankBannerMap[rank.id] ?? 'owner.png'}`;
            return (
              <div class="space-y-5">
                <div class="mx-auto w-[min(58vw,420px)]">
                  <img
                    src={bannerSrc}
                    alt={t(localeData, `about.team.ranks.${rank.id}`)}
                    class="w-full h-auto object-contain image-render-pixel drop-shadow-[0_10px_28px_rgba(0,0,0,0.35)]"
                    loading="lazy"
                  />
                </div>

                <div class="flex flex-wrap justify-center gap-5">
                  {members.map(username => (
                    <TeamMember username={username} rank={rank.id} size="md" />
                  ))}
                </div>
              </div>
            );
          })}
        </div>
        
        {teamRanks.length === 0 && (
          <div class="text-center py-12">
            <p class="font-pixel text-xs text-white/25">No team members configured.</p>
          </div>
        )}
      </div>
    </div>
  </section>
</MainLayout>