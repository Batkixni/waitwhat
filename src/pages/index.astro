---
import MainLayout from '@layouts/MainLayout.astro';
import ServerStatus from '@components/ServerStatus.astro';
import MinecraftText from '@components/MinecraftText.astro';
import LogoCarousel from '@components/ui/logo-carousel';
import GameModesExpandable from '@components/ui/game-modes-expandable';
import { GradientBars } from '@components/gradient-bars';
import { Mouse } from '@lucide/astro';
import { loadLocale, detectLocale, t } from '@utils/i18n';
import config from '@utils/config';


const { cookies, request } = Astro;
const locale = detectLocale(cookies, request.headers, Astro.url);
const localeData = await loadLocale(locale);

const gamemodes = config.gamemodes;
const partners = (config.partners || []).map((partner, i) => ({
  id: i,
  name: partner.name,
  img: partner.logo,
  url: partner.url,
}));
---

<MainLayout>
  <!-- Hero -->
  <section class="relative min-h-screen flex flex-col items-center justify-center px-5 pt-28 pb-20 overflow-hidden border-b border-white/[0.18]">
    <div class="absolute inset-0 z-0 overflow-hidden">
      <img
        src={config.server.banner}
        alt={config.server.name}
        class="w-full h-full object-cover opacity-45"
        onerror="this.style.display='none'"
      />
      <div class="absolute inset-0 bg-black/38"></div>
      <div class="absolute inset-0 bg-[linear-gradient(to_bottom,rgba(0,0,0,0.18),rgba(0,0,0,0.62))]"></div>
      <div class="absolute bottom-0 left-1/2 h-[40vw] max-h-[460px] min-h-[240px] w-[min(100%,72rem)] -translate-x-1/2 z-[11] pointer-events-none opacity-80 mix-blend-screen">
        <GradientBars
          client:load
          colors={["rgba(247,238,19,0)", "rgba(247,238,19,0.44)", "rgba(23,171,136,0.20)", "rgba(0,0,0,0)"]}
          numBars={24}
          minScale={0.10}
          maxScale={0.82}
          animation="wave"
          duration={2.8}
          delayStep={0.04}
          className="opacity-82 [mask-image:linear-gradient(to_bottom,transparent,black_22%,black_100%)]"
        />
      </div>
    </div>

    <!-- Ambient glow -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[500px] bg-[#F7EE13]/[0.07] rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute inset-x-0 bottom-0 h-56 bg-[linear-gradient(to_bottom,rgba(0,0,0,0),rgba(0,0,0,0.16)_22%,rgba(0,0,0,0.68)_70%,#000_100%)] pointer-events-none z-10"></div>
    
    <div class="relative z-20 flex flex-col items-center text-center max-w-3xl mx-auto">
      
      <!-- Subtitle -->
      <p class="font-pixel text-[11px] text-[#F7EE13]/70 tracking-[0.2em] uppercase mb-6">
        {t(localeData, 'home.subtitle')}
      </p>
      
      <!-- Title -->
      <div class="mb-6 px-4">
        <img
          src="/images/branding/banner-fusion-pixel-8px.png"
          alt={config.server.name}
          class="w-full max-w-[760px] h-auto object-contain mx-auto"
          onerror="this.style.display='none'"
        />
      </div>
      
      <!-- Description -->
      <p class="font-pixel text-xs sm:text-sm text-white/40 max-w-lg mx-auto leading-relaxed mb-10">
        {t(localeData, 'home.description')}
      </p>
      
      <!-- Server Status -->
      <div class="mb-12">
        <ServerStatus localeData={localeData} />
      </div>
      
      <!-- CTA -->
      <a
        href="#gamemodes"
        class="group inline-flex animate-float flex-col items-center gap-2 text-white/75 transition-colors hover:text-white"
        aria-label={t(localeData, 'home.cta')}
      >
        <Mouse class="w-8 h-8 sm:w-9 sm:h-9 text-white drop-shadow-[0_0_18px_rgba(255,255,255,0.28)]" stroke-width={1.8} aria-hidden="true" />
        <span class="font-pixel text-lg leading-none text-white drop-shadow-[0_0_10px_rgba(255,255,255,0.32)]" aria-hidden="true">↓</span>
      </a>
    </div>
  </section>

  <!-- Game Modes -->
  <section id="gamemodes" class="module-divider relative z-10 px-5 py-24">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <p class="font-pixel text-[10px] text-[#F7EE13]/50 tracking-[0.15em] uppercase mb-3">GAME MODES</p>
        <h2 class="font-pixel text-2xl sm:text-3xl text-white/90">{t(localeData, 'home.gamemodes.title')}</h2>
      </div>
      
      <GameModesExpandable
        client:load
        modes={gamemodes}
        comingSoonLabel={t(localeData, 'home.gamemodes.comingSoon')}
        modeLabel={t(localeData, 'home.gamemodes.modeLabel')}
        statusLabel={t(localeData, 'home.gamemodes.statusLabel')}
        focusLabel={t(localeData, 'home.gamemodes.focusLabel')}
        focusValue={t(localeData, 'home.gamemodes.focusValue')}
      />
    </div>
  </section>

  <!-- Partners -->
  <section class="module-divider-top relative z-10 px-5 py-24">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <p class="font-pixel text-[10px] text-[#F7EE13]/50 tracking-[0.15em] uppercase mb-3">PARTNERS</p>
        <h2 class="font-pixel text-2xl sm:text-3xl text-white/90">{t(localeData, 'home.partners.title')}</h2>
      </div>
      
      <LogoCarousel 
        client:load
        logos={partners}
        columnCount={3}
      />
    </div>
  </section>
</MainLayout>
