---
import '../styles/global.css';
import Navbar from '@components/Navbar.astro';
import Footer from '@components/Footer.astro';
import { BottomBlur } from '@components/ui/edge-blur';
import { loadLocale, detectLocale } from '@utils/i18n';
import config from '@utils/config';

interface Props {
  title?: string;
  description?: string;
  color?: string;
  image?: string;
}

const { cookies, request } = Astro;
const locale = detectLocale(cookies, request.headers, Astro.url);
const localeData = await loadLocale(locale);

const {
  title = localeData.meta?.title || config.server.name,
  description = localeData.meta?.description || config.server.description,
  color = '#F7EE13',
  image = localeData.meta?.image || config.server.banner
} = Astro.props;

const fullTitle = title;
const ogImage = image.startsWith('http') ? image : new URL(image, Astro.url.origin).toString();
---

<!DOCTYPE html>
<html lang={locale} class="bg-black">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content={color} />
  
  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.url} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content={config.server.name} />
  
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  
  <!-- Preconnect -->
  <link rel="preconnect" href="https://cdn.jsdelivr.net" />
  <link rel="dns-prefetch" href="https://api.mineatar.io" />
  
  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
</head>
<body class={`bg-black text-white min-h-screen flex flex-col antialiased locale-${locale}`}>
  <div class="fixed inset-0 bg-gradient-radial pointer-events-none z-0"></div>
  <div class="fixed inset-0 pointer-events-none z-0">
    <div class="absolute inset-y-0 left-1/2 w-[min(calc(100%_-_2.5rem),64rem)] -translate-x-1/2 border-x border-white/[0.10]"></div>
  </div>
  
  <Navbar locale={locale} localeData={localeData} />
  
  <main class="relative z-10 flex-1">
    <slot />
  </main>
  
  <Footer locale={locale} localeData={localeData} />
  
  <BottomBlur client:load height={140} hideOnFooter={true} />
  
  <script define:vars={{ locale }}>
    document.cookie = `lang=${locale};path=/;max-age=31536000;SameSite=Lax`;
  </script>
</body>
</html>
